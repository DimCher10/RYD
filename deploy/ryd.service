[Unit]
Description=RYD olympiad preparation application
After=network.target

[Service]
Type=simple
User=ryd
Group=ryd
WorkingDirectory=/opt/ryd
Environment=HOST=127.0.0.1
Environment=PORT=8000
Environment=RYD_DB_PATH=/opt/ryd/data/ryd.db
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 /opt/ryd/server.py
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/ryd/data

[Install]
WantedBy=multi-user.target
